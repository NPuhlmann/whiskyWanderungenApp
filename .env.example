# Whisky Hikes — runtime environment
#
# Copy to `.env` and fill in real values. `.env` is gitignored and is loaded at
# app startup by flutter_dotenv (see lib/main.dart). It is also bundled as a
# Flutter asset via pubspec.yaml (flutter.assets: - .env), so it ships with
# the app bundle at build time — do NOT put server-only secrets here.
#
# Canonical infra definition lives in terraform-supabase/; see QUICKSTART.md
# for the provisioning flow. For reuse of an existing Supabase project, pull
# the URL + anon key from the Supabase dashboard (Settings → API) and paste
# them below.

# ---- Supabase (required) ----
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<public-anon-key>

# Used by terraform-supabase/ when (re-)provisioning infra. Not required at app
# runtime, only for operators running `terraform apply`.
SUPABASE_ACCESS_TOKEN=<personal-access-token>

# ---- Stripe (test mode) ----
# Read in lib/data/services/payment/*. Use your own Stripe test keys; the
# _TEST suffix matches the variable names hard-coded in the Dart sources.
STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...
STRIPE_SECRET_KEY_TEST=sk_test_...

# ---- Google Pay / Apple Pay (test) ----
# Referenced by the `pay` package integration.
GOOGLE_PAY_MERCHANT_ID_TEST=
GOOGLE_PAY_MERCHANT_NAME_TEST=
APPLE_PAY_MERCHANT_ID_TEST=merchant.com.example.whiskyhikes.test
APPLE_MERCHANT_DISPLAY_NAME_TEST=Whisky Hikes (Test)

# ---- Misc ----
# Set to "true" to enable dev-only behavior (verbose logging, test UIs).
DEV_MODE=false
