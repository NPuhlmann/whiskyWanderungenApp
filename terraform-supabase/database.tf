# Kombinierte SQL-Datei für Supabase CLI Migration
resource "local_file" "combined_sql" {
  filename = "${path.module}/sql/combined.sql"
  content = join("\n\n-- ==================================================\n\n", [
    "-- Whisky Hikes Database Schema Setup",
    "-- Generated by Terraform for Supabase CLI migration",
    "",
    "-- 1. Create Tables",
    file("${path.module}/sql/01_create_tables.sql"),
    "",
    "-- 2. Create Functions", 
    file("${path.module}/sql/02_create_functions.sql"),
    "",
    "-- 3. Create Policies",
    file("${path.module}/sql/03_create_policies.sql"),
    "",
    "-- 4. Insert Sample Data",
    file("${path.module}/sql/04_insert_sample_data.sql")
  ])
}

# Supabase Migration Files Setup
resource "null_resource" "setup_migrations" {
  depends_on = [supabase_project.whisky_hikes, local_file.combined_sql]
  
  triggers = {
    project_id = supabase_project.whisky_hikes.id
    sql_changed = filemd5("${path.module}/sql/combined.sql")
  }

  provisioner "local-exec" {
    command = <<-EOT
      cd ${path.module}
      
      # Create supabase directory structure if it doesn't exist
      mkdir -p supabase/migrations
      mkdir -p supabase/seed.sql
      
      # Initialize supabase if not already initialized
      if [ ! -f "supabase/config.toml" ]; then
        echo "Initializing Supabase project..."
        supabase init
      fi
      
      # Create migration file with timestamp
      TIMESTAMP=$(date +"%Y%m%d%H%M%S")
      MIGRATION_FILE="supabase/migrations/${TIMESTAMP}_initial_schema.sql"
      
      # Copy schema setup to migration
      cp sql/01_create_tables.sql "$MIGRATION_FILE"
      echo "" >> "$MIGRATION_FILE"
      cat sql/02_create_functions.sql >> "$MIGRATION_FILE"
      echo "" >> "$MIGRATION_FILE"
      cat sql/03_create_policies.sql >> "$MIGRATION_FILE"
      
      # Copy sample data to seed file
      cp sql/04_insert_sample_data.sql supabase/seed.sql
      
      echo "Migration files created successfully!"
    EOT
  }
} 