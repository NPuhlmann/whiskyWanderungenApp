});
```

## Performance Testing

### 1. Mock Performance
```dart
test('should handle large datasets efficiently', () async {
  final largeHikeList = List.generate(1000, (i) => 
    TestHelpers.createTestHike(id: i));
  
  when(mockRepository.getAllHikes())
      .thenAnswer((_) async => largeHikeList);
  
  final stopwatch = Stopwatch()..start();
  await viewModel.loadHikes();
  stopwatch.stop();
  
  expect(stopwatch.elapsedMilliseconds, lessThan(100));
});
```

### 2. Memory Testing
```dart
test('should not leak memory', () async {
  final initialMemory = ProcessInfo.currentRss;
  
  for (int i = 0; i < 100; i++) {
    await viewModel.loadHikes();
    await viewModel.dispose();
  }
  
  final finalMemory = ProcessInfo.currentRss;
  expect(finalMemory - initialMemory, lessThan(1024 * 1024)); // 1MB
});
```

