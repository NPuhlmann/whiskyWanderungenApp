<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Reference / local-build template.
  In CI, distribute.yml generates this file at runtime so it can inject
  secrets (APPLE_TEAM_ID, IOS_PROVISIONING_PROFILE_NAME) directly.
  Update the placeholder values below only for local ad-hoc builds.
-->
<plist version="1.0">
<dict>
  <key>method</key>
  <string>app-store</string>
  <key>teamID</key>
  <string>YOUR_APPLE_TEAM_ID</string>
  <key>signingStyle</key>
  <string>manual</string>
  <key>provisioningProfiles</key>
  <dict>
    <key>com.puhlmann.whiskyHikes</key>
    <string>YOUR_PROVISIONING_PROFILE_NAME</string>
  </dict>
  <key>signingCertificate</key>
  <string>Apple Distribution</string>
  <key>uploadBitcode</key>
  <false/>
  <key>uploadSymbols</key>
  <true/>
  <key>compileBitcode</key>
  <false/>
</dict>
</plist>
